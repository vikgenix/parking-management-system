generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id String @id @default(uuid())

    name     String
    email    String  @unique
    phone    String  @unique
    password String?

    picture String?

    role     Role    @default(driver)
    isActive Boolean @default(true)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    sessions Session[]
}

model Session {
    id String @id @default(uuid())

    userAgent String
    browser   String
    os        String
    device    String

    location  String
    ipAddress String

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    expiresAt    DateTime
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
    lastActiveAt DateTime @default(now())
}

enum Role {
    driver
    admin
}
